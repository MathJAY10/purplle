APP_NAME=Store Intelligence System
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=store_intelligence
POSTGRES_USER=store_user
POSTGRES_PASSWORD=store_password
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_STREAM_NAME=store_intelligence.events
REDIS_CONSUMER_GROUP=store-intelligence-workers
REDIS_CONSUMER_NAME=worker-1

HOST=0.0.0.0
PORT=8000

CV_CONFIDENCE_THRESHOLD=0.35
CV_FRAME_SKIP=2
CV_DEBOUNCE_FRAMES=15
CV_TRACK_TTL_FRAMES=45
CV_DEBUG_VISUALIZATION=false
CV_LINE_X1=100
CV_LINE_Y1=100
CV_LINE_X2=500
CV_LINE_Y2=100
HEALTH_STALE_FEED_SECONDS=300
STORE_CONFIG_DIR=configs/stores
